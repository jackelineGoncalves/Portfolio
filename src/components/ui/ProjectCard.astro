---
import Chevron from "../../assets/svg/Chevron.astro";
import GitBranch from "../../assets/svg/GitBranch.astro";
import Button from "../ui/Button.astro";

interface TechItem {
  icon: any;
  label: string;
}

interface Props {
  name: string;
  smallDescription: string;
  onProgressTag?: boolean;
  workProjectTag?: boolean;
  hoveredTitle: string;
  fullDescription: string;
  technologiesIcons: TechItem[];
  projectType: string;
  hasCodeBtn?: boolean;
  hasDetailsBtn?: boolean;
}

const {
  name,
  smallDescription,
  onProgressTag = false,
  workProjectTag = false,
  hoveredTitle,
  fullDescription,
  technologiesIcons,
  projectType,
  hasCodeBtn = false,
  hasDetailsBtn = false,
} = Astro.props;
---

<article class="group relative w-full min-h-fit overflow-hidden rounded-[28px] border-[0.5px] border-secondary-1 bg-bg-surface p-4 md:p-5 shadow-[0_10px_30px_rgba(0,0,0,0.6)] transition-all duration-300 hover:shadow-[0_0_20px_rgba(103,232,249,0.35)]">
  <header class="flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
    <h3 class="text-lg md:text-xl font-bold gradient-text">
      {name}
    </h3>

    <div class="flex flex-wrap gap-2 lg:justify-end">
      {onProgressTag && (
        <div class="flex h-fit items-center justify-center gap-2 rounded-full border-[0.5px] border-secondary-4 px-3 py-1.5">
          <div class="flex h-4 w-4 items-center justify-center rounded-full bg-secondary-3">
            <div class="h-2.5 w-2.5 rounded-full bg-primary" />
          </div>
          <p class="text-xs text-text-secondary">In progress</p>
        </div>
      )}

      {workProjectTag && (
        <div class="flex h-fit items-center justify-center gap-2 rounded-full border-[0.5px] border-secondary-4 px-3 py-1.5">
          <p class="text-xs text-text-secondary">Work project</p>
        </div>
      )}
    </div>
  </header>

  <p class="pt-3 text-sm font-normal text-text-secondary">
    {smallDescription}
  </p>

  <slot name="preview" />

  <div class="absolute inset-0 z-20 bg-[#020817]/55 opacity-0 backdrop-blur-[14px] transition-all duration-500 group-hover:opacity-100">
    <div class="relative flex h-full flex-col justify-between gap-4 p-4 md:p-5">
      <div>
        <p class="text-xs uppercase text-primary/80">
          {projectType}
        </p>

        <h3 class="mt-2 text-base md:text-lg font-extrabold leading-tight text-white">
          {hoveredTitle}
        </h3>

        <p class="mt-3 text-xs md:text-sm leading-5 text-white/78">
          {fullDescription}
        </p>
      </div>

      <div class="flex w-full flex-wrap justify-center gap-4 pt-2 md:gap-6">
        {technologiesIcons.map((tech) => {
          const Icon = tech.icon;

          return (
            <div class="group/icon relative">
              <div class="flex items-center justify-center">
                <Icon class="h-8 w-8 md:h-9 md:w-9" />
              </div>

              <div class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-md bg-black/80 px-2 py-1 text-xs text-white opacity-0 transition-all duration-200 group-hover/icon:-translate-y-1 group-hover/icon:opacity-100">
                {tech.label}
              </div>
            </div>
          );
        })}
      </div>

      <div
        class={`flex w-full gap-4 ${
          hasCodeBtn && hasDetailsBtn ? "justify-between" : "justify-end"
        }`}
      >
        {hasDetailsBtn && (
          <Button
            label="View Project Details"
            variant="primary"
            href="#projects"
            size="sm"
            fullWidth={hasCodeBtn}
          >
            <Chevron slot="icon-right" />
          </Button>
        )}

        {hasCodeBtn && (
          <Button
            label="Code"
            variant="secondary"
            href="#projects"
            size="sm"
            fullWidth={hasDetailsBtn}
            class={hasDetailsBtn ? "max-w-[150px]" : ""}
          >
            <GitBranch slot="icon-left" />
          </Button>
        )}
      </div>
    </div>
  </div>
</article>