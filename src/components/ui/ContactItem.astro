---
import Github from "../../assets/svg/Github.astro";
import InfoBox from "./InfoBox.astro";

interface Props {
  contactMethod: "Github" | "Email" | "Phone Number" | "LinkedIn";
  href: string;
  icon: any;
}

const { contactMethod, href, icon: Icon } = Astro.props;
---

<a
  href={href}
  {...href.startsWith("http") && {
    target: "_blank",
    rel: "noopener noreferrer",
  }}
  target="_blank"
  rel="noopener noreferrer"
  class="bg-bg-surface/40 border border-secondary-1 flex py-4 px-6 rounded-[20px] items-center gap-4 backdrop-blur-2xl shadow-[0_10px_35px_rgba(0,0,0,0.35)] transition-all duration-300 ease-out hover:-translate-y-1.5 hover:border-primary/60"
>
  <div class="p-2 rounded-[14px] bg-primary/5">
    <Icon class="h-6 w-6 text-primary" />
  </div>
  <p class="text-white text-md font-medium">{contactMethod}</p>
</a>
