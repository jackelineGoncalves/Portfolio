---
import Globe from "../../assets/svg/Globe.astro";
import { LOCALES, type Locale } from "../../i18n/config";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const navItems = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Work Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Stack", href: "#stack" },
  { label: "Contact", href: "#contact" },
];

const localeLabels: Record<Locale, string> = {
  en: "En",
  es: "Es",
  pt: "Pt",
};
---

<header
  id="site-header"
  class="site-header fixed top-5 left-0 z-50 w-full transition-all duration-300"
>
  <div class="header-bg transition-all duration-300">
    <div class="container-main">
      <!-- MOBILE TOP BAR -->
      <div class="mobile-topbar flex items-center justify-between md:hidden">
        <!-- Lang selector — mobile -->
        <div class="lang-selector" id="lang-selector-mobile">
          <button
            type="button"
            class="lang-trigger h-13 px-4 bg-bg-surface/40 border border-secondary-1 inline-flex items-center gap-2 rounded-[18px] text-white backdrop-blur-xl"
            aria-haspopup="listbox"
            aria-expanded="false"
          >
            <Globe class="w-6 h-6" />
            <span class="font-semibold text-md leading-none"
              >{localeLabels[lang]}</span
            >
            <svg
              class="lang-chevron w-3 h-3 opacity-60"
              viewBox="0 0 12 8"
              fill="none"
            >
              <path
                d="M1 1L6 7L11 1"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>

          <ul class="lang-dropdown" role="listbox" aria-label="Select language">
            {
              LOCALES.map((loc) => (
                <li role="option" aria-selected={loc === lang}>
                  <a
                    href={`/${loc}/`}
                    class:list={["lang-option", loc === lang && "is-active"]}
                  >
                    {localeLabels[loc]}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <button
          id="menu-toggle"
          type="button"
          class="bg-bg-surface/40 border border-secondary-1 inline-flex h-13 w-13 items-center justify-center rounded-[18px] backdrop-blur-xl"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="hamburger">
            <span></span><span></span><span></span>
          </span>
        </button>
      </div>

      <!-- DESKTOP NAV -->
      <nav
        class="site-nav hidden items-center rounded-[28px] border border-secondary-1 bg-bg-surface/40 pl-10.5 pr-3 py-2 backdrop-blur-xl shadow-lg transition-all duration-300 md:flex"
        aria-label="Primary"
      >
        <ul class="flex w-full items-center justify-between">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="nav-link text-sm font-semibold md:text-base"
                >
                  {item.label}
                </a>
              </li>
            ))
          }

          <!-- Lang selector — desktop -->
          <li>
            <div class="lang-selector" id="lang-selector-desktop">
              <button
                type="button"
                class="lang-trigger inline-flex items-center gap-2 rounded-[18px] bg-[rgba(83,216,243,0.15)] px-4 py-2 text-white"
                aria-haspopup="listbox"
                aria-expanded="false"
              >
                <Globe class="w-5 h-5" />
                <span class="font-semibold">{localeLabels[lang]}</span>
                <svg
                  class="lang-chevron w-3 h-3 opacity-60"
                  viewBox="0 0 12 8"
                  fill="none"
                >
                  <path
                    d="M1 1L6 7L11 1"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </button>

              <ul
                class="lang-dropdown"
                role="listbox"
                aria-label="Select language"
              >
                {
                  LOCALES.map((loc) => (
                    <li role="option" aria-selected={loc === lang}>
                      <a
                        href={`/${loc}/`}
                        class:list={[
                          "lang-option",
                          loc === lang && "is-active",
                        ]}
                      >
                        {localeLabels[loc]}
                      </a>
                    </li>
                  ))
                }
              </ul>
            </div>
          </li>
        </ul>
      </nav>

      <!-- MOBILE DROPDOWN MENU -->
      <div id="mobile-menu" class="mobile-menu md:hidden">
        <div
          class="py-8 px-7 rounded-[28px] border border-secondary-1 bg-bg-surface/60 backdrop-blur-[20px]"
        >
          <ul class="flex flex-col">
            {
              navItems.map((item, index) => (
                <li class={index !== navItems.length - 1 ? "mb-8" : ""}>
                  <a
                    href={item.href}
                    class="mobile-nav-link inline-block text-md font-semibold leading-none text-white"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  let sectionObserver: IntersectionObserver | null = null;

  function setupNavbar() {
    const header = document.getElementById("site-header");
    const menuToggle = document.getElementById("menu-toggle");
    const md = window.matchMedia("(min-width: 768px)");

    if (!(header instanceof HTMLElement)) return;

    const syncScroll = () => {
      if (!md.matches) {
        header.classList.remove("scrolled");
        return;
      }
      header.classList.toggle("scrolled", window.scrollY > 80);
    };

    if (header.dataset.scrollBound !== "true") {
      header.dataset.scrollBound = "true";
      window.addEventListener("scroll", syncScroll);
      window.addEventListener("resize", syncScroll);
    }

    syncScroll();

    if (
      menuToggle instanceof HTMLButtonElement &&
      menuToggle.dataset.bound !== "true"
    ) {
      menuToggle.dataset.bound = "true";

      menuToggle.addEventListener("click", () => {
        const isOpen = header.classList.toggle("menu-open");
        menuToggle.setAttribute("aria-expanded", String(isOpen));
        menuToggle.setAttribute(
          "aria-label",
          isOpen ? "Close menu" : "Open menu",
        );
      });
    }

    document.querySelectorAll("#mobile-menu a").forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      if (link.dataset.bound === "true") return;

      link.dataset.bound = "true";

      link.addEventListener("click", () => {
        header.classList.remove("menu-open");
        if (menuToggle instanceof HTMLButtonElement) {
          menuToggle.setAttribute("aria-expanded", "false");
          menuToggle.setAttribute("aria-label", "Open menu");
        }
      });
    });

    // Active section tracking — disconnect previous observer before recreating
    if (sectionObserver) {
      sectionObserver.disconnect();
      sectionObserver = null;
    }

    const sectionIds = ["home", "about", "experience", "projects", "stack", "contact"];

    function setActive(id: string) {
      document.querySelectorAll(".nav-link, .mobile-nav-link").forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        link.classList.toggle("is-active", link.getAttribute("href") === `#${id}`);
      });
    }

    sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      {
        rootMargin: "-45% 0px -45% 0px",
        threshold: 0,
      }
    );

    sectionIds.forEach((id) => {
      const el = document.getElementById(id);
      if (el) sectionObserver!.observe(el);
    });

    function initLangSelector(id: string) {
      const root = document.getElementById(id);
      if (!(root instanceof HTMLElement)) return;

      const trigger = root.querySelector(".lang-trigger");
      const dropdown = root.querySelector(".lang-dropdown");

      if (!(trigger instanceof HTMLButtonElement)) return;
      if (!(dropdown instanceof HTMLElement)) return;

      const open = () => {
        dropdown.classList.add("is-open");
        trigger.setAttribute("aria-expanded", "true");
      };

      const close = () => {
        dropdown.classList.remove("is-open");
        trigger.setAttribute("aria-expanded", "false");
      };

      const toggle = () => {
        if (dropdown.classList.contains("is-open")) close();
        else open();
      };

      if (trigger.dataset.bound !== "true") {
        trigger.dataset.bound = "true";

        trigger.addEventListener("click", (e) => {
          e.stopPropagation();
          toggle();
        });
      }

      if (root.dataset.docClickBound !== "true") {
        root.dataset.docClickBound = "true";

        document.addEventListener("click", (e) => {
          const target = e.target;
          if (!(target instanceof Node)) return;
          if (!root.contains(target)) close();
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") close();
        });
      }
    }

    initLangSelector("lang-selector-mobile");
    initLangSelector("lang-selector-desktop");
  }

  setupNavbar();
  document.addEventListener("astro:page-load", setupNavbar);
</script>

<style>
  .site-header.scrolled {
    top: 0;
  }

  .site-header.scrolled .header-bg {
    background: transparent;
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--color-secondary-1);
  }

  .site-header.scrolled .site-nav {
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .mobile-topbar {
    padding-top: 0.25rem;
  }

  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    pointer-events: none;
    opacity: 0;
    transform: translateY(-10px);
    margin-top: 0;
    transition:
      max-height 0.3s ease,
      opacity 0.25s ease,
      transform 0.25s ease,
      margin-top 0.25s ease;
  }

  .site-header.menu-open .mobile-menu {
    max-height: 500px;
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
    margin-top: 1rem;
  }

  .mobile-nav-link {
    position: relative;
    color: rgba(255, 255, 255, 0.96);
    transition: all 0.2s ease;
  }

  .mobile-nav-link:hover {
    background: linear-gradient(to right, var(--primary), var(--primary-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hamburger {
    position: relative;
    width: 22px;
    height: 16px;
    display: inline-block;
  }

  .hamburger span {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2.5px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    transition:
      transform 0.3s ease,
      top 0.3s ease,
      opacity 0.25s ease;
  }

  .hamburger span:nth-child(1) {
    top: 0;
  }

  .hamburger span:nth-child(2) {
    top: 6.5px;
  }

  .hamburger span:nth-child(3) {
    top: 13px;
  }

  .site-header.menu-open .hamburger span:nth-child(1) {
    top: 6.5px;
    transform: rotate(45deg);
  }

  .site-header.menu-open .hamburger span:nth-child(2) {
    opacity: 0;
  }

  .site-header.menu-open .hamburger span:nth-child(3) {
    top: 6.5px;
    transform: rotate(-45deg);
  }

  .nav-link {
    position: relative;
    color: rgba(255, 255, 255, 0.9);
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 2px;
    background: linear-gradient(to right, var(--primary), var(--primary-2));
    transition: width 0.25s ease;
  }

  .nav-link:hover {
    background: linear-gradient(to right, var(--primary), var(--primary-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.is-active {
    background: linear-gradient(to right, var(--primary), var(--primary-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .nav-link.is-active::after {
    width: 100%;
  }

  .mobile-nav-link.is-active {
    background: linear-gradient(to right, var(--primary), var(--primary-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .lang-selector {
    position: relative;
    display: inline-block;
  }

  .lang-trigger {
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .lang-trigger:hover {
    opacity: 0.85;
  }

  .lang-chevron {
    transition: transform 0.25s ease;
  }

  .lang-trigger[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 96px;
    border: 1px solid var(--color-secondary-1);
    border-radius: 14px;
    padding: 6px;
    list-style: none;
    margin: 0;
    background: rgba(10, 16, 24, 0.55);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
    z-index: 100;
  }

  .lang-dropdown.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .lang-dropdown.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .lang-option {
    display: block;
    padding: 8px 16px;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    text-align: center;
    text-decoration: none;
  }

  .lang-option:hover {
    color: #fff;
  }

  .lang-option.is-active {
    background-color: rgba(83, 216, 243, 0.15);
    color: #fff;
  }

  @media (max-width: 767px) {
    .site-header {
      top: 0.9rem;
    }

    .container-main {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
  }
</style>
