---
interface Props {
  defaultTab?: "personal" | "work";
}

const { defaultTab = "personal" } = Astro.props;

const tabs = [
  { id: "personal", label: "Personal Projects" },
  { id: "work", label: "Work Projects" },
];
---

<div
  class="projects-tabs-wrapper mx-auto w-fit"
  data-project-tabs-root
  data-default-tab={defaultTab}
  data-active-tab={defaultTab}
>
  <div
    class="projects-tabs relative grid w-fit grid-cols-2 rounded-[28px] border border-secondary-1 bg-bg-surface/40 p-1.5 backdrop-blur-xl"
    role="tablist"
    aria-label="Project type selector"
  >
    <span class="tab-indicator" aria-hidden="true"></span>

    {
      tabs.map((tab) => {
        const isActive = tab.id === defaultTab;

        return (
          <button
            type="button"
            class:list={[
              "project-tab relative z-10 inline-flex h-[52px] items-center justify-center rounded-[22px] px-5 md:px-7 text-sm md:text-base font-semibold transition-colors duration-300",
              isActive && "is-active",
            ]}
            role="tab"
            aria-selected={isActive ? "true" : "false"}
            data-tab-trigger={tab.id}
          >
            <span>{tab.label}</span>
          </button>
        );
      })
    }
  </div>
</div>

<script>
  type ProjectTabType = "personal" | "work";

  document
    .querySelectorAll<HTMLElement>("[data-project-tabs-root]")
    .forEach((root) => {
      const tabButtons =
        root.querySelectorAll<HTMLButtonElement>("[data-tab-trigger]");
      const defaultTab =
        (root.dataset.defaultTab as ProjectTabType) || "personal";

      const setActiveTab = (targetId: ProjectTabType, emitEvent = true) => {
        root.setAttribute("data-active-tab", targetId);

        tabButtons.forEach((button) => {
          const isActive = button.dataset.tabTrigger === targetId;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        if (emitEvent) {
          root.dispatchEvent(
            new CustomEvent("project-tab-change", {
              bubbles: true,
              detail: { value: targetId },
            }),
          );
        }
      };

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const tabId = button.dataset.tabTrigger as ProjectTabType | undefined;
          if (!tabId) return;
          setActiveTab(tabId);
        });
      });

      setActiveTab(defaultTab, false);
    });
</script>

<style>
  .projects-tabs {
    position: relative;
    overflow: hidden;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .project-tab {
    color: var(--color-secondary-5);
  }

  .project-tab:hover {
    color: rgba(255, 255, 255, 0.96);
  }

  .project-tab.is-active {
    color: white;
  }

  .tab-indicator {
    position: absolute;
    top: 6px;
    left: 6px;
    bottom: 6px;
    width: calc(50% - 6px);
    border-radius: 22px;
    pointer-events: none;

    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04) 0%,
        rgba(255, 255, 255, 0.02) 100%
      ),
      rgba(8, 22, 34, 0.72);

    border: 1px solid rgba(255, 255, 255, 0.07);

    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 8px 20px rgba(0, 0, 0, 0.22);

    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .projects-tabs-wrapper[data-active-tab="personal"] .tab-indicator {
    transform: translateX(0%);
  }

  .projects-tabs-wrapper[data-active-tab="work"] .tab-indicator {
    transform: translateX(100%);
  }

  @media (max-width: 767px) {
    .project-tab {
      padding-left: 1rem;
      padding-right: 1rem;
    }
  }
</style>