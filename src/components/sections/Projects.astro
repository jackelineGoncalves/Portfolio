---
import mova from "../../assets/images/MOVA-1.png";
import Expo from "../../assets/svg/Expo.astro";
import Postgre from "../../assets/svg/Postgre.astro";
import React from "../../assets/svg/React.astro";
import Supabase from "../../assets/svg/Supabase.astro";
import TypeScript from "../../assets/svg/TypeScript.astro";
import ProjectCard from "../ui/ProjectCard.astro";

const projects = [
  {
    name: "SaaS Platform",
    smallDescription:
      "An immersive 3D e-commerce platform featuring virtual storefronts, interactive product visualization.",
    onProgressTag: true,
    workProjectTag: true,
    hoveredTitle: "App for personal trainer and client management",
    fullDescription:
      "An immersive 3D e-commerce platform featuring virtual storefronts, interactive product visualization.",
    technologiesIcons: [
      { icon: React, label: "React Native" },
      { icon: Expo, label: "Expo" },
      { icon: Supabase, label: "Supabase" },
      { icon: Postgre, label: "PostgreSQL" },
      { icon: TypeScript, label: "TypeScript" },
    ],
    projectType: "Personal Project",
    hasCodeBtn: true,
    hasDetailsBtn: true,
  },
  {
    name: "SaaS Platform",
    smallDescription:
      "An immersive 3D e-commerce platform featuring virtual storefronts, interactive product visualization.",
    onProgressTag: true,
    workProjectTag: true,
    hoveredTitle: "App for personal trainer and client management",
    fullDescription:
      "An immersive 3D e-commerce platform featuring virtual storefronts, interactive product visualization.",
    technologiesIcons: [
      { icon: React, label: "React Native" },
      { icon: Expo, label: "Expo" },
      { icon: Supabase, label: "Supabase" },
      { icon: Postgre, label: "PostgreSQL" },
      { icon: TypeScript, label: "TypeScript" },
    ],
    projectType: "Personal Project",
    hasCodeBtn: true,
    hasDetailsBtn: true,
  },
  {
    name: "SaaS Platform",
    smallDescription:
      "An immersive 3D e-commerce platform featuring virtual storefronts, interactive product visualization.",
    onProgressTag: true,
    workProjectTag: true,
    hoveredTitle: "App for personal trainer and client management",
    fullDescription:
      "An immersive 3D e-commerce platform featuring virtual storefronts, interactive product visualization.",
    technologiesIcons: [
      { icon: React, label: "React Native" },
      { icon: Expo, label: "Expo" },
      { icon: Supabase, label: "Supabase" },
      { icon: Postgre, label: "PostgreSQL" },
      { icon: TypeScript, label: "TypeScript" },
    ],
    projectType: "Personal Project",
    hasCodeBtn: true,
    hasDetailsBtn: true,
  },
];
---

<section
  class="container-main grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-5 lg:gap-8"
  data-projects-reveal id="projects"
>
  {
    projects.map((project, index) => {
      const isLast = index === projects.length - 1;
      const isOdd = projects.length % 2 !== 0;
      const shouldCenter = isLast && isOdd;

      const directionClass = shouldCenter
        ? "reveal-card reveal-card-center"
        : index % 2 === 0
          ? "reveal-card reveal-card-left"
          : "reveal-card reveal-card-right";

      return (
        <div
          class:list={[
            shouldCenter ? "md:col-span-2 flex justify-center" : "w-full",
            directionClass,
          ]}
          style={`--reveal-delay: ${index * 120}ms;`}
        >
          <div class={shouldCenter ? "w-full md:w-1/2" : "w-full"}>
            <ProjectCard {...project}>
              <div slot="preview" class="relative mt-4 flex items-end justify-center">
                <div class="absolute bottom-8 left-1/2 h-28 w-28 -translate-x-1/2 rounded-full bg-primary/10 blur-3xl" />

                <img
                  src={mova.src}
                  alt="App menu screen"
                  class="relative z-0 w-[24%] translate-x-5 translate-y-5 -rotate-12 object-cover shadow-[0_20px_40px_rgba(0,0,0,0.55)] transition-transform duration-500 group-hover:scale-[0.98] md:w-[22%]"
                />

                <img
                  src={mova.src}
                  alt="Main app screen"
                  class="relative z-10 w-[32%] translate-y-10 object-cover shadow-[0_24px_50px_rgba(0,0,0,0.65)] transition-transform duration-500 group-hover:scale-[0.98] md:w-[30%]"
                />

                <img
                  src={mova.src}
                  alt="App stats screen"
                  class="relative z-0 w-[24%] -translate-x-5 translate-y-5 rotate-12 object-cover shadow-[0_20px_40px_rgba(0,0,0,0.55)] transition-transform duration-500 group-hover:scale-[0.98] md:w-[22%]"
                />
              </div>
            </ProjectCard>
          </div>
        </div>
      );
    })
  }
</section>

<script>
  const section = document.querySelector("[data-projects-reveal]");
  const cards = document.querySelectorAll(".reveal-card");

  if (section && cards.length) {
    const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (mediaQuery.matches) {
      cards.forEach((card) => card.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            cards.forEach((card) => card.classList.add("is-visible"));
            obs.unobserve(entry.target);
          });
        },
        {
          threshold: 0.18,
          rootMargin: "0px 0px -8% 0px",
        }
      );

      observer.observe(section);
    }
  }
</script>

<style>
  .reveal-card {
    opacity: 0;
    will-change: transform, opacity;
    transition:
      opacity 650ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  .reveal-card-left {
    transform: translate3d(-18px, 28px, 0);
  }

  .reveal-card-right {
    transform: translate3d(18px, 28px, 0);
  }

  .reveal-card-center {
    transform: translate3d(0, 28px, 0);
  }

  .reveal-card.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-card,
    .reveal-card-left,
    .reveal-card-right,
    .reveal-card-center {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>