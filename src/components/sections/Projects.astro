---
import ProjectCard from "../ui/ProjectCard.astro";
import { projects } from "../../data/projects";
import type { Locale } from "../../i18n/config";
import { getProjectContent } from "../../i18n/utils";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section
  class="container-main grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-5 lg:gap-8"
  data-projects-reveal
>
  {
    projects.map((project, index) => {
      const isLast = index === projects.length - 1;
      const isOdd = projects.length % 2 !== 0;
      const shouldCenter = isLast && isOdd;

      const directionClass = shouldCenter
        ? "project-reveal-card project-reveal-card--center"
        : index % 2 === 0
          ? "project-reveal-card project-reveal-card--left"
          : "project-reveal-card project-reveal-card--right";

      return (
        <div
          class:list={[
            shouldCenter ? "md:col-span-2 flex justify-center" : "w-full",
            directionClass,
          ]}
          style={`--reveal-delay: ${index * 120}ms;`}
        >
          <div class={shouldCenter ? "w-full md:w-1/2" : "w-full"}>
            <ProjectCard
              {...project}
              {...getProjectContent(lang, project.slug)}
              detailHref={`/${lang}/projects/${project.slug}/`}
            >
              <div
                slot="preview"
                class="relative mt-4 flex items-end justify-center"
              >
                <div class="absolute bottom-8 left-1/2 h-28 w-28 -translate-x-1/2 rounded-full bg-primary/10 blur-3xl" />
                <img
                  src={project.image.src}
                  alt={`${project.name} screen left`}
                  class="relative z-0 w-[24%] translate-x-5 translate-y-5 -rotate-12 object-cover shadow-[0_20px_40px_rgba(0,0,0,0.55)] transition-transform duration-500 group-hover:scale-[0.98] md:w-[22%]"
                />
                <img
                  src={project.image.src}
                  alt={`${project.name} main screen`}
                  transition:name={`project-image-${project.slug}`}
                  class="relative z-10 w-[32%] translate-y-10 object-cover shadow-[0_24px_50px_rgba(0,0,0,0.65)] transition-transform duration-500 group-hover:scale-[0.98] md:w-[30%]"
                />
                <img
                  src={project.image.src}
                  alt={`${project.name} screen right`}
                  class="relative z-0 w-[24%] -translate-x-5 translate-y-5 rotate-12 object-cover shadow-[0_20px_40px_rgba(0,0,0,0.55)] transition-transform duration-500 group-hover:scale-[0.98] md:w-[22%]"
                />
              </div>
            </ProjectCard>
          </div>
        </div>
      );
    })
  }
</section>

<script>
  function setupProjectsReveal() {
    const section = document.querySelector("[data-projects-reveal]");
    if (!(section instanceof HTMLElement)) return;
    if (section.dataset.revealBound === "true") return;

    section.dataset.revealBound = "true";

    const cards = section.querySelectorAll(".project-reveal-card");
    const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (mediaQuery.matches) {
      cards.forEach((card) => card.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          cards.forEach((card) => card.classList.add("is-visible"));
          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -5% 0px" }
    );

    observer.observe(section);
  }

  setupProjectsReveal();
  document.addEventListener("astro:page-load", setupProjectsReveal);
</script>

<style>
  .project-reveal-card {
    opacity: 0;
    will-change: transform, opacity;
    transition:
      opacity 650ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .project-reveal-card--left {
    transform: translate3d(-18px, 28px, 0);
  }
  .project-reveal-card--right {
    transform: translate3d(18px, 28px, 0);
  }
  .project-reveal-card--center {
    transform: translate3d(0, 28px, 0);
  }
  .project-reveal-card.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-reveal-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
