---
import SpecialtyCard from "../ui/SpecialtyCard.astro";
import type { Locale } from "../../i18n/config";
import enSpecialtys from "../../i18n/locales/en/specialtys.json";
import esSpecialtys from "../../i18n/locales/es/specialtys.json";
import ptSpecialtys from "../../i18n/locales/pt/specialtys.json";

interface Props {
  lang: Locale;
}

const localeData = { en: enSpecialtys, es: esSpecialtys, pt: ptSpecialtys };

const { lang } = Astro.props;
const data = localeData[lang] ?? enSpecialtys;

const accents = ["purple", "cyan", "blue", "cyan"] as const;
const icons = ["design", "frontend", "mobile", "backend"] as const;
const tags = [
  ["Figma", "Design Systems", "User Flows", "Prototyping", "UI/UX"],
  ["React", "Next.js", "TypeScript", "Tailwind", "GraphQL"],
  ["React Native", "Flutter", "Expo", "App Store", "Play Store"],
  ["Node.js", "PostgreSQL", "Supabase", "REST", "RLS"],
];

const items = data.items.map((item, i) => ({
  ...item,
  accent: accents[i],
  icon: icons[i],
  tags: tags[i],
}));
---

<div
  class="container-main grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-4"
  data-specialties-reveal
>
  {
    items.map((specialty, index) => (
      <div
        class="specialty-reveal-card h-full"
        style={`--reveal-delay: ${index * 100}ms;`}
      >
        <SpecialtyCard {...specialty} />
      </div>
    ))
  }
</div>

<script>
  function setupSpecialtiesReveal() {
    const section = document.querySelector("[data-specialties-reveal]");
    if (!(section instanceof HTMLElement)) return;

    const cards = section.querySelectorAll(".specialty-reveal-card");
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      cards.forEach((c) => c.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          cards.forEach((c) => c.classList.add("is-visible"));
          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -6% 0px" }
    );

    observer.observe(section);
  }

  setupSpecialtiesReveal();
  document.addEventListener("astro:page-load", setupSpecialtiesReveal);
</script>

<style>
  .specialty-reveal-card {
    opacity: 0;
    transform: translateY(28px);
    will-change: transform, opacity;
    transition:
      opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .specialty-reveal-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .specialty-reveal-card { opacity: 1; transform: none; transition: none; }
  }
</style>
