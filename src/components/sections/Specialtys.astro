---
import SpecialtyCard from "../ui/SpecialtyCard.astro";

const specialties = [
  {
    title: "UX/UI Design",
    description:
      "jndjenf fejbfe fj43ibi4bt cyebyfbef feybfhyebf efybeyfbe feyfeyvfevfe fevbfwf ",
  },
  {
    title: "UX/UI Design",
    description: "jndjenf fejbfe fj43ibi4bt ",
  },
  {
    title: "UX/UI Design",
    description: "jndjenf fejbfe fj43ibi4bt ",
  },
];
---

<div
  class=" grid grid-cols-2 md:grid-cols-3 gap-5"
  data-specialties-reveal
>
  {
    specialties.map((specialty, index) => {
      const isLast = index === specialties.length - 1;
      const isOdd = specialties.length % 2 !== 0;
      const shouldCenter = isLast && isOdd;

      const directionClass = shouldCenter
        ? "reveal-card reveal-card-center"
        : index % 2 === 0
          ? "reveal-card reveal-card-left"
          : "reveal-card reveal-card-right";

      return (
        <div
          class:list={[
            shouldCenter
              ? "col-span-2 flex justify-center md:col-span-1 md:block"
              : "w-full",
            directionClass,
          ]}
          style={`--reveal-delay: ${index * 120}ms;`}
        >
          <div
            class={shouldCenter
              ? "w-[calc(50%-0.625rem)] md:w-full h-full"
              : "w-full h-full"}
          >
            <SpecialtyCard {...specialty} />
          </div>
        </div>
      );
    })
  }
</div>

<script>
  const section = document.querySelector("[data-specialties-reveal]");
  const cards = document.querySelectorAll(".reveal-card");

  if (section && cards.length) {
    const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (mediaQuery.matches) {
      cards.forEach((card) => card.classList.add("is-visible"));
    } else {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;

            cards.forEach((card) => card.classList.add("is-visible"));
            obs.unobserve(entry.target);
          });
        },
        {
          threshold: 0.18,
          rootMargin: "0px 0px -8% 0px",
        },
      );

      observer.observe(section);
    }
  }
</script>

<style>
  .reveal-card {
    opacity: 0;
    will-change: transform, opacity;
    transition:
      opacity 650ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  .reveal-card-left {
    transform: translate3d(-18px, 28px, 0);
  }

  .reveal-card-right {
    transform: translate3d(18px, 28px, 0);
  }

  .reveal-card-center {
    transform: translate3d(0, 28px, 0);
  }

  .reveal-card.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-card,
    .reveal-card-left,
    .reveal-card-right,
    .reveal-card-center {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>