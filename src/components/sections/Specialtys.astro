---
import SpecialtyCard from "../ui/SpecialtyCard.astro";

const specialties = [
  {
    icon: "design" as const,
    accent: "purple" as const,
    title: "UX/UI Design",
    description:
      "I design complete systems, not just screens. From user flows and component libraries to final handoff — every interaction is intentional.",
    tags: ["Figma", "Design Systems", "User Flows", "Prototyping", "UI/UX"],
  },
  {
    icon: "frontend" as const,
    accent: "cyan" as const,
    title: "Frontend & Web",
    description:
      "Pixel-perfect interfaces that perform. I build responsive, accessible web apps with React, Next.js and TypeScript — from design system to production.",
    tags: ["React", "Next.js", "TypeScript", "Tailwind", "GraphQL"],
  },
  {
    icon: "mobile" as const,
    accent: "blue" as const,
    title: "Mobile Development",
    description:
      "Cross-platform apps built for the real world. I've shipped to App Store and Google Play — handling architecture, UX, and release pipeline end-to-end.",
    tags: ["React Native", "Flutter", "Expo", "App Store", "Play Store"],
  },
  {
    icon: "backend" as const,
    accent: "cyan" as const,
    title: "Backend & Databases",
    description:
      "Solid foundations that scale. I design multi-tenant architectures, RESTful APIs, and secure data models — Node.js, PostgreSQL, Supabase and more.",
    tags: ["Node.js", "PostgreSQL", "Supabase", "REST", "RLS"],
  },
];
---

<div
  class="container-main grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-4"
  data-specialties-reveal
>
  {
    specialties.map((specialty, index) => (
      <div
        class="specialty-reveal-card h-full"
        style={`--reveal-delay: ${index * 100}ms;`}
      >
        <SpecialtyCard {...specialty} />
      </div>
    ))
  }
</div>

<script>
  function setupSpecialtiesReveal() {
    const section = document.querySelector("[data-specialties-reveal]");
    if (!(section instanceof HTMLElement)) return;

    const cards = section.querySelectorAll(".specialty-reveal-card");
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      cards.forEach((c) => c.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          cards.forEach((c) => c.classList.add("is-visible"));
          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -6% 0px" }
    );

    observer.observe(section);
  }

  setupSpecialtiesReveal();
  document.addEventListener("astro:page-load", setupSpecialtiesReveal);
</script>

<style>
  .specialty-reveal-card {
    opacity: 0;
    transform: translateY(28px);
    will-change: transform, opacity;
    transition:
      opacity 600ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 600ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }
  .specialty-reveal-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .specialty-reveal-card { opacity: 1; transform: none; transition: none; }
  }
</style>
