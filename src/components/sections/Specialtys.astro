---
import SpecialtyCard from "../ui/SpecialtyCard.astro";

const specialties = [
  {
    title: "UX/UI Design",
    description:
      "jndjenf fejbfe fj43ibi4bt cyebyfbef feybfhyebf efybeyfbe feyfeyvfevfe fevbfwf ",
  },
  {
    title: "UX/UI Design",
    description: "jndjenf fejbfe fj43ibi4bt ",
  },
  {
    title: "UX/UI Design",
    description: "jndjenf fejbfe fj43ibi4bt ",
  },
];
---

<div
  class="grid grid-cols-2 gap-5 md:grid-cols-3"
  data-specialties-reveal
>
  {
    specialties.map((specialty, index) => {
      const isLast = index === specialties.length - 1;
      const isOdd = specialties.length % 2 !== 0;
      const shouldCenter = isLast && isOdd;

      const directionClass = shouldCenter
        ? "specialty-reveal-card specialty-reveal-card--center"
        : index % 2 === 0
          ? "specialty-reveal-card specialty-reveal-card--left"
          : "specialty-reveal-card specialty-reveal-card--right";

      return (
        <div
          class:list={[
            shouldCenter
              ? "col-span-2 flex justify-center md:col-span-1 md:block"
              : "w-full",
            directionClass,
          ]}
          style={`--reveal-delay: ${index * 120}ms;`}
        >
          <div
            class={shouldCenter
              ? "h-full w-[calc(50%-0.625rem)] md:w-full"
              : "h-full w-full"}
          >
            <SpecialtyCard {...specialty} />
          </div>
        </div>
      );
    })
  }
</div>

<script>
  function setupSpecialtiesReveal() {
    const section = document.querySelector("[data-specialties-reveal]");
    if (!(section instanceof HTMLElement)) return;

    const cards = section.querySelectorAll(".specialty-reveal-card");
    const mediaQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    if (mediaQuery.matches) {
      cards.forEach((card) => card.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          cards.forEach((card) => card.classList.add("is-visible"));
          obs.unobserve(entry.target);
        });
      },
      {
        threshold: 0.18,
        rootMargin: "0px 0px -8% 0px",
      },
    );

    observer.observe(section);
  }

  setupSpecialtiesReveal();
  document.addEventListener("astro:page-load", setupSpecialtiesReveal);
</script>

<style>
  .specialty-reveal-card {
    opacity: 0;
    will-change: transform, opacity;
    transition:
      opacity 650ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  .specialty-reveal-card--left {
    transform: translate3d(-18px, 28px, 0);
  }

  .specialty-reveal-card--right {
    transform: translate3d(18px, 28px, 0);
  }

  .specialty-reveal-card--center {
    transform: translate3d(0, 28px, 0);
  }

  .specialty-reveal-card.is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .specialty-reveal-card,
    .specialty-reveal-card--left,
    .specialty-reveal-card--right,
    .specialty-reveal-card--center {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>