---
import Chevron from "../../assets/svg/Chevron.astro";
import Github from "../../assets/svg/Github.astro";
import LinkedIn from "../../assets/svg/LinkedIn.astro";
import Email from "../../assets/svg/Email.astro";
import Button from "../ui/Button.astro";
import { useTranslations } from "../../i18n";
import type { Locale } from "../../i18n/config";
import profileImage from "../../assets/images/profile.png";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const { t, tArray } = useTranslations(lang, "hero");
---

<section
  class="relative min-h-screen overflow-hidden hero animate-hero"
  data-hero
>
  <div
    class="glow-circle absolute w-full h-250 -top-220 left-1/2 -translate-x-1/2 z-0"
  >
  </div>

  <div
    class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-8 items-center min-h-screen container-main pt-24 pb-24 md:pb-0 md:pt-0"
  >
    <div
      class="relative z-10 grid gap-7 text-center md:text-left justify-items-center md:justify-items-start"
    >
      <header class="grid">
        <div
          class="availability-badge bg-primary-2/15 border border-primary-2/20 mb-4"
        >
          <span class="dot"></span>
          {t("badge")}
        </div>

        <h1 class="text-white text-2xl md:text-3xl font-bold">
          {t("greeting")}
        </h1>

        <h2 class="gradient-text text-xl font-semibold">{t("role")}</h2>
      </header>

      <div class="grid gap-10">
        <div class="flex flex-col gap-2">
          {tArray("description").map((paragraph) => (
            <p class="text-text-secondary text-sm">{paragraph}</p>
          ))}
        </div>

        <div
          class="flex items-center justify-center md:justify-start gap-8 md:gap-10.5"
        >
          <Button label={t("cta")} variant="primary" href="#projects">
            <Chevron slot="icon-right" />
          </Button>

          <nav aria-label={t("socials.ariaLabel")}>
            <ul class="flex items-center gap-5">
              <li>
                <a
                  class="social-btn social-btn--github"
                  href="https://github.com/jackelineGoncalves"
                >
                  <span class="social-btn__icon">
                    <Github />
                  </span>
                </a>
              </li>

              <li>
                <a
                  class="social-btn social-btn--linkedin"
                  href="https://www.linkedin.com/in/jackeline-goncalves-dev/"
                >
                  <span class="social-btn__icon">
                    <LinkedIn />
                  </span>
                </a>
              </li>

              <li>
                <a
                  class="social-btn social-btn--gmail"
                  href="mailto:jackeline.camara04@gmail.com"
                >
                  <span class="social-btn__icon">
                    <Email />
                  </span>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>

    <aside
      class="relative z-10 flex items-center justify-center md:justify-end md:translate-x-6"
    >
      <img
        src={profileImage.src}
        alt={t("profileImageAlt")}
        class="block h-auto w-[clamp(160px,60vw,420px)] object-contain rotate-[8deg] -translate-x-1.5 drop-shadow-[0_24px_45px_rgba(0,0,0,0.35)] md:max-h-[82vh] md:w-[clamp(280px,34vw,500px)] md:rotate-10 md:-translate-x-4.5 lg:w-[clamp(340px,32vw,560px)] lg:rotate-11 lg:-translate-x-6.5"
      />
    </aside>
  </div>
</section>

<style>
  .animate-hero {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .animate-hero.show {
    opacity: 1;
    transform: translateY(0);
  }

  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-primary-2);
    backdrop-filter: blur(8px);
    animation: fadeSlideUp 0.6s ease forwards;
    opacity: 0;
    transform: translateY(6px);
    width: fit-content;
  }

  .availability-badge .dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-primary-2);
    box-shadow: 0 0 8px var(--color-primary-2);
    animation: pulse 1.6s infinite ease-in-out;
  }

  @keyframes fadeSlideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.6);
      opacity: 0.6;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-hero {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .availability-badge {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function setupHero() {
    const hero = document.querySelector("[data-hero]");
    if (!(hero instanceof HTMLElement)) return;

    requestAnimationFrame(() => {
      hero.classList.add("show");
    });
  }

  setupHero();
  document.addEventListener("astro:page-load", setupHero);
</script>
