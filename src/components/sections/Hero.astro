---
import Chevron from "../../assets/svg/Chevron.astro";
import Github from "../../assets/svg/Github.astro";
import LinkedIn from "../../assets/svg/LinkedIn.astro";
import Email from "../../assets/svg/Email.astro";
import Button from "../ui/Button.astro";
---

<section class="relative min-h-screen overflow-hidden">
  <canvas
    id="stars-canvas"
    class="absolute inset-0 w-full h-full pointer-events-none z-0"
  ></canvas>

  <div
    class="glow-circle absolute w-full h-250 top-[-880px] left-1/2 -translate-x-1/2 z-0"
  ></div>

  <div
    class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-8 items-center min-h-screen container-main pt-24 pb-24 md:pb-0 md:pt-0"
  >
    <div
      class="relative z-10 grid gap-7 text-center md:text-left justify-items-center md:justify-items-start"
    >
      <header class="grid gap-2">
        <h1 class="text-white text-2xl md:text-3xl font-bold">
          Hey! I'm Jackeline
        </h1>
        <h2 class="gradient-text text-xl font-semibold">Software Developer</h2>
      </header>

      <div class="grid gap-10">
        <p class="text-text-secondary text-sm">
          Mobile Developer specializing in React Native, TypeScript and Flutter.
          I build high-performance mobile applications with a focus on clean
          architecture and great user experience.
        </p>

        <div
          class="flex items-center justify-center md:justify-start gap-8 md:gap-10.5"
        >
          <Button label="View CV" variant="primary" href="#projects">
            <Chevron slot="icon-right" />
          </Button>

          <nav aria-label="Social links">
            <ul class="flex items-center gap-5">
              <li>
                <a class="social-btn social-btn--github" href="#">
                  <span class="social-btn__icon">
                    <Github />
                  </span>
                </a>
              </li>

              <li>
                <a class="social-btn social-btn--linkedin" href="#">
                  <span class="social-btn__icon">
                    <LinkedIn />
                  </span>
                </a>
              </li>

              <li>
                <a
                  class="social-btn social-btn--gmail"
                  href="mailto:tuemail@ejemplo.com"
                >
                  <span class="social-btn__icon">
                    <Email />
                  </span>
                </a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
    </div>

    <aside
      class="relative z-10 flex items-center justify-center md:justify-end md:translate-x-6"
    >
      <img
        src="/src/assets/images/profile.png"
        alt="Profile card"
        class="block h-auto w-[clamp(160px,60vw,420px)] object-contain rotate-[8deg] -translate-x-[6px] drop-shadow-[0_24px_45px_rgba(0,0,0,0.35)] md:max-h-[82vh] md:w-[clamp(280px,34vw,500px)] md:rotate-[10deg] md:-translate-x-[18px] lg:w-[clamp(340px,32vw,560px)] lg:rotate-[11deg] lg:-translate-x-[26px]"
      />
    </aside>
  </div>
</section>

<script>
  const section = document.querySelector("section");
  const canvas = document.getElementById("stars-canvas") as HTMLCanvasElement;
  const ctx = canvas.getContext("2d")!;

  function resize() {
    if (!section) return;

    canvas.width = window.innerWidth;
    canvas.height = section.scrollHeight;
  }

  resize();
  window.addEventListener("resize", resize);

  const NUM_STARS = 180;
  const stars = Array.from({ length: NUM_STARS }, () => ({
    x: Math.random(),
    y: Math.random(),
    radius: Math.random() * 1.4 + 0.2,
    opacity: Math.random() * 0.6 + 0.2,
    twinkleSpeed: Math.random() * 0.008 + 0.002,
    twinkleOffset: Math.random() * Math.PI * 2,
  }));

  interface ShootingStar {
    x: number;
    y: number;
    vx: number;
    vy: number;
    tailLength: number;
    life: number;
    maxLife: number;
  }

  const shootingStars: ShootingStar[] = [];

  function spawnShootingStar() {
    const speed = Math.random() * 5 + 4;

    const minDeg = 30;
    const maxDeg = 60;
    const baseDeg = minDeg + Math.random() * (maxDeg - minDeg);
    const quadrant = Math.floor(Math.random() * 4);

    let angleDeg: number;
    if (quadrant === 0) angleDeg = baseDeg;
    else if (quadrant === 1) angleDeg = 180 - baseDeg;
    else if (quadrant === 2) angleDeg = 180 + baseDeg;
    else angleDeg = 360 - baseDeg;

    const angle = angleDeg * (Math.PI / 180);
    const vx = Math.cos(angle) * speed;
    const vy = Math.sin(angle) * speed;

    let x: number, y: number;

    if (vx > 0 && vy > 0) {
      if (Math.random() < 0.5) {
        x = Math.random() * canvas.width;
        y = 0;
      } else {
        x = 0;
        y = Math.random() * canvas.height;
      }
    } else if (vx < 0 && vy > 0) {
      if (Math.random() < 0.5) {
        x = Math.random() * canvas.width;
        y = 0;
      } else {
        x = canvas.width;
        y = Math.random() * canvas.height;
      }
    } else if (vx < 0 && vy < 0) {
      if (Math.random() < 0.5) {
        x = Math.random() * canvas.width;
        y = canvas.height;
      } else {
        x = canvas.width;
        y = Math.random() * canvas.height;
      }
    } else {
      if (Math.random() < 0.5) {
        x = Math.random() * canvas.width;
        y = canvas.height;
      } else {
        x = 0;
        y = Math.random() * canvas.height;
      }
    }

    const stepsToExitX =
      vx > 0 ? (canvas.width - x) / vx : vx < 0 ? -x / vx : Infinity;
    const stepsToExitY =
      vy > 0 ? (canvas.height - y) / vy : vy < 0 ? -y / vy : Infinity;
    const maxLife = Math.min(stepsToExitX, stepsToExitY);

    shootingStars.push({
      x,
      y,
      vx,
      vy,
      tailLength: Math.random() * 80 + 80,
      life: 0,
      maxLife,
    });
  }

  function scheduleShootingStar() {
    const delay = Math.random() * 2500 + 2500;
    setTimeout(() => {
      spawnShootingStar();
      scheduleShootingStar();
    }, delay);
  }

  scheduleShootingStar();

  let frame = 0;

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    frame++;

    for (const s of stars) {
      const twinkle = Math.sin(frame * s.twinkleSpeed + s.twinkleOffset) * 0.3;
      const alpha = Math.max(0.05, s.opacity + twinkle);

      ctx.beginPath();
      ctx.arc(
        s.x * canvas.width,
        s.y * canvas.height,
        s.radius,
        0,
        Math.PI * 2,
      );
      ctx.fillStyle = `rgba(255, 255, 255, ${alpha})`;
      ctx.fill();
    }

    for (let i = shootingStars.length - 1; i >= 0; i--) {
      const s = shootingStars[i];
      s.life++;
      s.x += s.vx;
      s.y += s.vy;

      if (s.life >= s.maxLife) {
        shootingStars.splice(i, 1);
        continue;
      }

      const progress = s.life / s.maxLife;
      const fadeIn = Math.min(1, progress / 0.15);
      const fadeOut = Math.min(1, (1 - progress) / 0.15);
      const opacity = Math.min(fadeIn, fadeOut);

      const speed = Math.hypot(s.vx, s.vy);
      const tailX = s.x - s.vx * (s.tailLength / speed);
      const tailY = s.y - s.vy * (s.tailLength / speed);

      const grad = ctx.createLinearGradient(tailX, tailY, s.x, s.y);
      grad.addColorStop(0, `rgba(255, 255, 255, 0)`);
      grad.addColorStop(0.6, `rgba(255, 255, 255, ${opacity * 0.4})`);
      grad.addColorStop(1, `rgba(255, 255, 255, ${opacity})`);

      ctx.beginPath();
      ctx.moveTo(tailX, tailY);
      ctx.lineTo(s.x, s.y);
      ctx.strokeStyle = grad;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(s.x, s.y, 1.8, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  draw();
</script>