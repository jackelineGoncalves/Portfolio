---
import BriefCase from "../../assets/svg/BriefCase.astro";
import IconBox from "..//ui/InfoBox.astro";
import type { Locale } from "../../i18n/config";
import enExperience from "../../i18n/locales/en/experience.json";
import esExperience from "../../i18n/locales/es/experience.json";
import ptExperience from "../../i18n/locales/pt/experience.json";

interface Props {
  lang: Locale;
}

const localeData = { en: enExperience, es: esExperience, pt: ptExperience };

const { lang } = Astro.props;
const data = localeData[lang] ?? enExperience;

const sides = ["left", "right", "left", "right"] as const;
const technologies = [
  ["Flutter", "Dart", "Firebase", "REST API", "App Store", "Google Play"],
  ["React Native", "Expo", "TypeScript", "Supabase", "PostgreSQL", "Figma"],
  ["Express.js", "React", "Ollama"],
  ["React", "Next.js", "TypeScript", "GraphQL", "Directus CMS", "REST API"],

];

// FALTAN TRADUCCIONES DE AI INTERNSHIP
const items = data.items.map((item, i) => ({ ...item, side: sides[i], technologies: technologies[i] }));
---

<section class="relative overflow-hidden">
  <div
    class="hidden lg:block glow-circle absolute w-35 h-125 top-45 -left-17.5 -translate-x-1/2"
  ></div>

  <div
    class="hidden lg:block glow-circle absolute w-35 h-125 top-130 -right-50 -translate-x-1/2"
  ></div>

  <div
    class="lg:hidden glow-circle absolute top-1/2 -translate-x-1/2 -translate-y-1/2 w-35 h-250 -right-60"
  ></div>

  <div class="container-main">
    <div data-timeline class="relative mx-auto py-8">
      <div
        class="absolute left-0 top-0 h-full w-px bg-secondary-2 lg:left-1/2 lg:-translate-x-1/2"
      ></div>

      <div
        data-line-active
        class="timeline-line-active absolute left-0 top-0 z-1 h-0 w-px lg:left-1/2 lg:-translate-x-1/2"
      ></div>

      {
        items.map((item, index) => {
          const isLast = index === items.length - 1;

          return (
            <article
              class={`timeline-item relative w-full pl-10 lg:w-1/2 lg:pl-0 ${
                !isLast ? "mb-16 lg:mb-20" : ""
              } ${item.side === "right" ? "lg:ml-[50%]" : ""}`}
              data-item
              data-side={item.side}
            >
              <span
                class={`timeline-dot absolute top-8 z-3 h-3 w-3 rounded-full border border-primary bg-primary shadow-[0_0_10px_rgba(103,232,249,0.9),0_0_24px_rgba(103,232,249,0.28)] left-0 -translate-x-1/2 ${
                  item.side === "right"
                    ? "lg:left-0 lg:translate-x-[-50%]"
                    : "lg:left-auto lg:right-0 lg:translate-x-[50%]"
                }`}
              >
                <span class="absolute -inset-1.5 rounded-full border border-primary/20" />
              </span>

              <div
                class={`timeline-card relative rounded-[28px] border-[0.5px] border-secondary-1 bg-bg-surface p-6 shadow-[0_10px_35px_rgba(0,0,0,0.35)] backdrop-blur-xl lg:p-8 ${
                  item.side === "right" ? "lg:ml-15" : "lg:mr-15"
                }`}
              >
                <div class="pointer-events-none absolute inset-0 rounded-[inherit] shadow-[inset_0_0_60px_rgba(103,232,249,0.04)]" />

                <div class="relative z-1">
                  <div class="flex gap-6 items-start">
                    <IconBox variant="primary">
                      <BriefCase class="h-5 w-5 text-primary" />
                    </IconBox>

                    <div>
                      <h3 class="text-lg font-extrabold leading-none text-white">
                        {item.title}
                      </h3>
                      <p class="mt-1 text-md font-bold gradient-text">
                        {item.company}
                      </p>
                      <p class="mt-1 text-xs text-text-secondary">
                        {item.period}
                      </p>
                    </div>
                  </div>

                  <ul class="mt-6 grid gap-3">
                    {item.bullets.map((bullet) => (
                      <li class="relative pl-6 text-sm leading-[1.65] text-text-secondary">
                        <span class="absolute left-0 top-0 text-md leading-none text-primary">
                          ›
                        </span>
                        {bullet}
                      </li>
                    ))}
                  </ul>

                  <div class="mt-5 flex flex-wrap gap-2 w-full">
                    {item.technologies.map((tech) => (
                      <span class="rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-xs font-medium text-primary">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<script>
  const initTimeline = () => {
    const timeline = document.querySelector<HTMLElement>("[data-timeline]");
    const activeLine = document.querySelector<HTMLElement>("[data-line-active]");
    const items = document.querySelectorAll<HTMLElement>("[data-item]");

    if (!timeline || !activeLine || !items.length) return;

    const updateLine = () => {
      const rect = timeline.getBoundingClientRect();
      const progress = ((window.innerHeight * 0.7 - rect.top) / rect.height) * 100;
      activeLine.style.height = `${Math.max(0, Math.min(100, progress))}%`;
    };

    const observer = new IntersectionObserver(
      (entries) => { entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add("is-visible"); }); },
      { threshold: 0.18 }
    );

    items.forEach((item) => observer.observe(item));
    updateLine();
    window.addEventListener("scroll", updateLine, { passive: true });
    window.addEventListener("resize", updateLine);
  };

  initTimeline();
  document.addEventListener("astro:after-swap", initTimeline);
</script>

<style>
  .timeline-item { position: relative; z-index: 2; }
  .timeline-dot { opacity: 0; transition: opacity 0.45s ease; }
  .timeline-item.is-visible .timeline-dot { opacity: 1; }
  .timeline-card { opacity: 0; transform: translateY(40px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .timeline-item.is-visible .timeline-card { opacity: 1; transform: translateY(0); }
  .timeline-line-active {
    background: linear-gradient(to bottom, rgba(103,232,249,0) 0%, rgba(103,232,249,0.45) 18%, rgba(103,232,249,0.95) 50%, rgba(103,232,249,0.45) 82%, rgba(103,232,249,0) 100%);
    box-shadow: 0 0 10px rgba(103,232,249,0.55), 0 0 24px rgba(103,232,249,0.22);
    transition: height 0.08s linear;
    overflow: visible;
  }
  .timeline-line-active::before {
    content: ""; position: absolute; inset: 0; left: 50%; width: 8px;
    transform: translateX(-50%); border-radius: 999px;
    background: linear-gradient(to bottom, rgba(103,232,249,0) 0%, rgba(103,232,249,0.18) 20%, rgba(103,232,249,0.35) 50%, rgba(103,232,249,0.18) 80%, rgba(103,232,249,0) 100%);
    filter: blur(6px); pointer-events: none;
  }
  @media (min-width: 1024px) {
    .timeline-item[data-side="left"] .timeline-card { transform: translateX(-56px); }
    .timeline-item[data-side="right"] .timeline-card { transform: translateX(56px); }
    .timeline-item.is-visible .timeline-card { transform: translateX(0); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .timeline-dot, .timeline-card, .timeline-line-active { transition: none; }
    .timeline-dot, .timeline-card { opacity: 1; transform: none; }
  }
</style>
