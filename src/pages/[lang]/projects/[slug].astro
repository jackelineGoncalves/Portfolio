---
import { projects } from "../../../data/projects";
import Layout from "../../../layouts/Layout.astro";
import { LOCALES, type Locale } from "../../../i18n/config";
import { useTranslations, getProjectContent } from "../../../i18n/utils";
import "../../../styles/global.css";
import Chevron from "../../../assets/svg/Chevron.astro";
import Code from "../../../assets/svg/Code.astro";

export function getStaticPaths() {
  return LOCALES.flatMap((lang) =>
    projects.map((project) => ({
      params: { lang, slug: project.slug },
      props: { project, lang },
    })),
  );
}

const { project, lang } = Astro.props as {
  project: (typeof projects)[number];
  lang: Locale;
};

const { t } = useTranslations(lang, "projectDetail");
const content = getProjectContent(lang, project.slug);
const backHref = `/${lang}/#projects`;

const previewImages = project.previewImages?.length
  ? project.previewImages
  : [project.image];

const firstImage = previewImages[0];
const secondImage = previewImages[1] ?? previewImages[0];
const thirdImage = previewImages[2] ?? previewImages[0];
---

<Layout lang={lang} showNav={false} title={project.name}>
  <div class="project-detail">
    <div class="container-main pt-16 pb-4">
      <a
        href={backHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-secondary-5 transition-colors duration-200 ease-in-out hover:text-white"
      >
        <Chevron class="h4 w-5 rotate-180" />
        {t("back")}
      </a>
    </div>

    <section
      class="container-main grid grid-cols-1 gap-12 pt-8 pb-16 md:grid-cols-2 md:items-center md:gap-16"
    >
      <div>
        <div class="mb-6 flex flex-wrap gap-2">
          {
            project.onProgressTag && (
              <span class="tag tag--progress">
                <span class="tag-dot" />
                {t("tags.inProgress")}
              </span>
            )
          }

          {
            project.workProjectTag && (
              <span class="tag tag--work">{t("tags.work")}</span>
            )
          }

          <span class="tag tag--type">{content.projectType ?? project.projectType}</span>
        </div>

        <h1
          transition:name={`project-title-${project.slug}`}
          class="detail-title gradient-text mb-4 text-2xl font-extrabold leading-[1.1]"
        >
          {project.name}
        </h1>

        <div class="gap-2 flex flex-col">
          {
            content.fullDescription.map((p: string) => (
              <p class="text-sm font-normal text-text-secondary">{p}</p>
            ))
          }
        </div>

        <div class="mt-6 flex items-stretch gap-4">
          <div
            class="w-0.75 rounded-full bg-primary-2 shadow-[0_0_12px_rgba(83,235,243,0.35)]"
          >
          </div>

          <div>
            <span
              class="text-xs font-semibold uppercase tracking-wider text-secondary-5"
            >
              {t("categories")}
            </span>

            <p class="mt-1 text-sm text-white/70">
              {project.categories.join(" | ")}
            </p>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 pt-9">
          {
            project.liveUrl && (
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary-detail"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M6 4H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2M10 2h4m0 0v4m0-4L7 9"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                {t("liveDemo")}
              </a>
            )
          }

          {
            project.codeUrl && (
              <a
                href={project.codeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary-detail"
              >
                <Code />
                {t("sourceCode")}
              </a>
            )
          }

          {
            project.appStoreUrl && (
              <a
                href={project.appStoreUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary-detail"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
                {t("appStore")}
              </a>
            )
          }

          {
            project.playStoreUrl && (
              <a
                href={project.playStoreUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary-detail"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M3.18 23.76c.3.17.64.22.98.14l12.09-6.98-2.55-2.55-10.52 9.39zM.54 1.03C.2 1.4 0 1.96 0 2.67v18.66c0 .71.2 1.27.54 1.64l.09.08 10.46-10.46v-.25L.63.95.54 1.03zM20.08 10.65l-2.89-1.67-2.87 2.87 2.87 2.87 2.91-1.68c.83-.48.83-1.26-.02-1.39zM3.18.24l12.09 6.98-2.55 2.55L2.2.38 3.18.24z"/>
                </svg>
                {t("playStore")}
              </a>
            )
          }
        </div>
      </div>

      <div class="relative flex items-end justify-center py-4">
        {
          project.previewVariant === "triple-phone" && (
            <div class="relative flex w-full max-w-125 items-end justify-center">
              <div class="absolute bottom-10 left-1/2 h-32 w-32 -translate-x-1/2 rounded-full bg-primary/10 blur-3xl" />

              <img
                src={firstImage.src}
                alt={`${project.name} screen left`}
                loading="lazy"
                class="relative z-0 w-[26%] translate-x-6 translate-y-6 -rotate-12 rounded-[18px] object-contain shadow-[0_20px_40px_rgba(0,0,0,0.55)]"
              />

              <img
                src={secondImage.src}
                alt={`${project.name} main screen`}
                transition:name={`project-image-${project.slug}`}
                loading="eager"
                class="relative z-10 w-[34%] translate-y-12 rounded-[22px] object-contain shadow-[0_24px_50px_rgba(0,0,0,0.65)]"
              />

              <img
                src={thirdImage.src}
                alt={`${project.name} screen right`}
                loading="lazy"
                class="relative z-0 w-[26%] -translate-x-6 translate-y-6 rotate-12 rounded-[18px] object-contain shadow-[0_20px_40px_rgba(0,0,0,0.55)]"
              />
            </div>
          )
        }

        {
          project.previewVariant === "two-screens" && (
            <div class="relative flex w-full max-w-125 items-end justify-center gap-6">
              <div class="absolute bottom-8 left-1/2 h-28 w-28 -translate-x-1/2 rounded-full bg-primary/10 blur-3xl" />

              <img
                src={firstImage.src}
                alt={`${project.name} screen 1`}
                loading="lazy"
                class="relative z-10 w-[28%] rounded-[20px] object-contain shadow-[0_20px_40px_rgba(0,0,0,0.55)]"
              />

              <img
                src={secondImage.src}
                alt={`${project.name} screen 2`}
                transition:name={`project-image-${project.slug}`}
                loading="eager"
                class="relative z-20 w-[32%] rounded-[20px] object-contain shadow-[0_24px_50px_rgba(0,0,0,0.65)]"
              />
            </div>
          )
        }

        {
          project.previewVariant === "single-screen" && (
            <div class="relative flex w-full justify-center">
              <div class="absolute inset-0 mx-auto h-36 w-36 rounded-full bg-primary/10 blur-3xl" />

              <img
                src={firstImage.src}
                alt={`${project.name} preview`}
                transition:name={`project-image-${project.slug}`}
                loading="eager"
                class="relative z-10 w-[82%] max-w-125 rounded-[24px] object-contain shadow-[0_24px_50px_rgba(0,0,0,0.65)]"
              />
            </div>
          )
        }
      </div>
    </section>

    {
      content.metrics.length > 0 && (
        <section class="container-main pb-16">
          <h2 class="section-heading">{t("impact")}</h2>
          <div class="metrics-grid">
            {content.metrics.map((metric) => (
              <div class="metric-card">
                <span class="metric-value gradient-text">{metric.value}</span>
                <span class="metric-label">{metric.label}</span>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <section class="container-main pb-18">
      <h2 class="section-heading">{t("techStack")}</h2>

      <div class="flex flex-wrap gap-2 md:gap-4">
        {
          project.technologiesIcons.map((tech) => {
            const Icon = tech.icon;

            return (
              <div class="tech-chip flex items-center gap-2 rounded-full bg-bg-surface px-4 py-2 text-sm font-semibold text-text-secondary outline-1 outline-secondary-1 transition-all duration-200 ease-in-out hover:outline-2 hover:outline-primary/70">
                <Icon class="h-5 w-5" />
                <span>{tech.label}</span>
              </div>
            );
          })
        }
      </div>
    </section>

    <section class="container-main">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="cs-card">
          <div class="cs-icon cs-icon--challenge">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M10 2L2 7v6l8 5 8-5V7L10 2z"
                stroke="#53EBF3"
                stroke-width="1.5"
                stroke-linejoin="round"></path>
              <path
                d="M10 10v4M10 7v.5"
                stroke="#53EBF3"
                stroke-width="1.5"
                stroke-linecap="round"></path>
            </svg>
          </div>

          <h3 class="cs-title">{t("challenge")}</h3>
          <p class="cs-text">{content.challenge}</p>
        </div>

        <div class="cs-card">
          <div class="cs-icon cs-icon--solution">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="8" stroke="#3090E9" stroke-width="1.5"
              ></circle>
              <path
                d="M7 10l2 2 4-4"
                stroke="#3090E9"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>

          <h3 class="cs-title">{t("solution")}</h3>
          <p class="cs-text">{content.solution}</p>
        </div>
      </div>
    </section>

    <section
      class="container-main pt-18"
      class:list={[project.galleryImages?.length ? "pb-18" : "pb-32"]}
    >
      <h2 class="section-heading">{t("keyFeatures")}</h2>

      <div class="features-grid">
        {
          content.features.map((feature, i) => (
            <div class="feature-card" style={`--delay: ${i * 80}ms`}>
              <div class="feature-number">{String(i + 1).padStart(2, "0")}</div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-desc">{feature.description}</p>
            </div>
          ))
        }
      </div>
    </section>

    {
      project.galleryImages && project.galleryImages.length > 0 && (
        <section class="container-main pb-32 pt-4">
          <h2 class="section-heading">{t("gallery")}</h2>

          <button
            class="gallery-cta"
            id="open-gallery-cta"
            type="button"
            aria-label={`Open ${project.name} gallery`}
          >
            <div class="gallery-cta__content">
              <div class="gallery-cta__icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M4 7a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v10a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V7Z"
                    stroke="currentColor"
                    stroke-width="1.8"
                  />
                  <path
                    d="m8 15 2.5-2.5a1.5 1.5 0 0 1 2.12 0L16 16"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <circle cx="15.5" cy="8.5" r="1.5" fill="currentColor" />
                </svg>
              </div>

              <div class="gallery-cta__text">
                <span class="gallery-cta__eyebrow">
                  {t("galleryScreenshots")}
                </span>
                <h3 class="gallery-cta__title">{t("galleryViewFull")}</h3>
              </div>
            </div>

            <div class="gallery-cta__arrow">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path
                  d="M7 17 17 7M17 7H8M17 7v9"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
          </button>

          <div class="hidden-gallery-items" aria-hidden="true">
            {project.galleryImages.map((img, i) => (
              <button
                type="button"
                data-gallery-index={i}
                data-gallery-src={img.src}
                aria-label={`View ${project.name} screenshot ${i + 1}`}
                tabindex="-1"
              >
                <img
                  src={img.src}
                  alt={`${project.name} screenshot ${i + 1}`}
                  loading="lazy"
                />
              </button>
            ))}
          </div>

          <div
            id="gallery-lightbox"
            class="lightbox"
            aria-modal="true"
            role="dialog"
            aria-hidden="true"
          >
            <button
              id="lightbox-close"
              class="lightbox-close"
              aria-label="Close"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path
                  d="M18 6L6 18M6 6l12 12"
                  stroke="white"
                  stroke-width="2"
                  stroke-linecap="round"
                />
              </svg>
            </button>

            <button
              id="lightbox-prev"
              class="lightbox-nav lightbox-nav--prev"
              aria-label="Previous"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path
                  d="M15 18l-6-6 6-6"
                  stroke="white"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>

            <div class="lightbox-content">
              <img id="lightbox-img" src="" alt="" class="lightbox-img" />
              <p id="lightbox-counter" class="lightbox-counter" />
            </div>

            <button
              id="lightbox-next"
              class="lightbox-nav lightbox-nav--next"
              aria-label="Next"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path
                  d="M9 18l6-6-6-6"
                  stroke="white"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
          </div>
        </section>
      )
    }
  </div>
</Layout>

<style is:global>
  .project-detail {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    color: white;
  }

  .project-detail > * {
    position: relative;
    z-index: 1;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 500;
    border: 1px solid;
  }

  .tag--progress {
    border-color: rgba(83, 235, 243, 0.3);
    color: var(--primary);
    background: rgba(83, 235, 243, 0.07);
  }

  .tag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 6px var(--primary);
    animation: pulse 1.6s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }

    50% {
      transform: scale(1.6);
      opacity: 0.6;
    }
  }

  .tag--work {
    border-color: rgba(48, 144, 233, 0.3);
    color: var(--primary-2);
    background: rgba(48, 144, 233, 0.07);
  }

  .tag--type {
    border-color: var(--secondary-1);
    color: var(--secondary-5);
    background: transparent;
  }

  .btn-primary-detail,
  .btn-secondary-detail {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.25rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary-detail {
    background: var(--primary-2);
    color: var(--dark);
    box-shadow: 0 0 20px rgba(48, 144, 233, 0.3);
  }

  .btn-primary-detail:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 28px rgba(48, 144, 233, 0.45);
  }

  .btn-secondary-detail {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .btn-secondary-detail:hover {
    border-color: var(--primary);
    box-shadow: 0 0 16px rgba(83, 235, 243, 0.15);
  }

  .section-heading {
    font-size: 1.4rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 1.75rem;
    position: relative;
    padding-left: 1rem;
  }

  .section-heading::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 100%;
    background: var(--color-primary-2);
    border-radius: 999px;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .metrics-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 1.5rem 1rem;
    border-radius: 20px;
    border: 1px solid var(--secondary-1);
    background: var(--bg-surface);
    text-align: center;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .metric-card:hover {
    border-color: rgba(83, 235, 243, 0.4);
    box-shadow: 0 0 20px rgba(83, 235, 243, 0.06);
  }

  .metric-value {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .metric-label {
    font-size: 0.75rem;
    color: var(--secondary-5);
    font-weight: 500;
    text-align: center;
    line-height: 1.4;
  }

  .cs-card {
    padding: 1.75rem;
    border-radius: 24px;
    border: 1px solid var(--secondary-1);
    background: var(--bg-surface);
    position: relative;
    overflow: hidden;
  }

  .cs-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .cs-icon--challenge {
    background: rgba(83, 235, 243, 0.08);
    border: 1px solid rgba(83, 235, 243, 0.15);
  }

  .cs-icon--solution {
    background: rgba(48, 144, 233, 0.08);
    border: 1px solid rgba(48, 144, 233, 0.15);
  }

  .cs-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .cs-text {
    font-size: 0.9rem;
    color: var(--secondary-5);
    line-height: 1.7;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .feature-card {
    position: relative;
    padding: 1.75rem;
    border-radius: 24px;
    border: 1px solid var(--secondary-1);
    background: var(--bg-surface);
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0ms)
      forwards;
  }

  .feature-card:hover {
    border-color: rgba(83, 235, 243, 0.693);
    box-shadow: 0 0 24px rgba(83, 235, 243, 0.08);
    transform: translateY(-4px);
  }

  .feature-number {
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.6rem;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--secondary-5);
    line-height: 1.65;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* GALLERY CTA */
  .gallery-cta {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.3rem 1.4rem;
    border-radius: 24px;
    border: 1px solid var(--secondary-1);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.02),
        rgba(255, 255, 255, 0.01)
      ),
      var(--bg-surface);
    color: white;
    text-align: left;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .gallery-cta:hover {
    transform: translateY(-2px);
    border-color: rgba(83, 235, 243, 0.35);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.28),
      0 0 0 1px rgba(83, 235, 243, 0.08);
  }

  .gallery-cta__content {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  .gallery-cta__icon {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    color: var(--primary);
    background: rgba(83, 235, 243, 0.08);
    border: 1px solid rgba(83, 235, 243, 0.16);
  }

  .gallery-cta__text {
    min-width: 0;
  }

  .gallery-cta__eyebrow {
    display: block;
    margin-bottom: 0.2rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary-5);
  }

  .gallery-cta__title {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 700;
    color: white;
  }

  .gallery-cta__desc {
    margin: 0.28rem 0 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--secondary-5);
  }

  .gallery-cta__arrow {
    flex-shrink: 0;
    color: white;
    opacity: 0.8;
    transition:
      transform 0.25s ease,
      opacity 0.25s ease;
  }

  .gallery-cta:hover .gallery-cta__arrow {
    transform: translate(2px, -2px);
    opacity: 1;
  }

  .hidden-gallery-items {
    display: none;
  }

  /* LIGHTBOX */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(2, 8, 23, 0.92);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    max-width: 90vw;
    max-height: 90vh;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 16px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.8);
  }

  .lightbox-counter {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
  }

  .lightbox-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    z-index: 1;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    z-index: 1;
  }

  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-nav--prev {
    left: 1.25rem;
  }

  .lightbox-nav--next {
    right: 1.25rem;
  }
</style>

<script>
  function setupGallery() {
    const lightbox = document.getElementById("gallery-lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
    const lightboxCounter = document.getElementById("lightbox-counter");
    const btnClose = document.getElementById("lightbox-close");
    const btnPrev = document.getElementById("lightbox-prev");
    const btnNext = document.getElementById("lightbox-next");
    const openGalleryCta = document.getElementById("open-gallery-cta");

    if (!lightbox || !lightboxImg || !lightboxCounter) return;

    const safeBox = lightbox;
    const safeImg = lightboxImg;
    const safeCounter = lightboxCounter;

    const items = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-index]"));

    if (!items.length) return;

    const srcs = items.map((item) => item.dataset.gallerySrc ?? "");

    let current = 0;

    function open(index: number) {
      current = index;
      safeImg.src = srcs[current] ?? "";
      safeImg.alt = `Screenshot ${current + 1}`;
      safeCounter.textContent = `${current + 1} / ${srcs.length}`;
      safeBox.classList.add("is-open");
      safeBox.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function close() {
      safeBox.classList.remove("is-open");
      safeBox.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    function prev() {
      open((current - 1 + srcs.length) % srcs.length);
    }

    function next() {
      open((current + 1) % srcs.length);
    }

    openGalleryCta?.addEventListener("click", () => open(0));
    btnClose?.addEventListener("click", close);
    btnPrev?.addEventListener("click", prev);
    btnNext?.addEventListener("click", next);

    safeBox.addEventListener("click", (e) => {
      if (e.target === safeBox) close();
    });

    document.addEventListener("keydown", (e) => {
      if (!safeBox.classList.contains("is-open")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") prev();
      if (e.key === "ArrowRight") next();
    });
  }

  setupGallery();
  document.addEventListener("astro:page-load", setupGallery);
</script>
