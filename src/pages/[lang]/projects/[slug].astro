---
import { projects } from "../../../data/projects";
import type { ProjectCategory } from "../../../data/projects";
import Layout from "../../../layouts/Layout.astro";
import { LOCALES, type Locale } from "../../../i18n/config";
import "../../../styles/global.css";
import Chevron from "../../../assets/svg/Chevron.astro";
import Code from "../../../assets/svg/Code.astro";

export function getStaticPaths() {
  return LOCALES.flatMap((lang) =>
    projects.map((project) => ({
      params: { lang, slug: project.slug },
      props: { project, lang },
    })),
  );
}

const { project, lang } = Astro.props as {
  project: (typeof projects)[number];
  lang: Locale;
};

const backHref = `/${lang}/#projects`;
---

<Layout lang={lang} showNav={false} title={project.name}>
  <div class="project-detail">
    <!-- BACK -->
    <div class="container-main pt-16 pb-4">
      <a
        href={backHref}
        class="inline-flex items-center gap-2 text-sm font-semibold text-secondary-5 transition-colors duration-200 ease-in-out hover:text-white"
      >
        <Chevron class="h4 w-5 rotate-180" />
        Back to projects
      </a>
    </div>

    <!-- HERO -->
    <section
      class="container-main grid grid-cols-1 gap-12 pt-8 pb-16 md:grid-cols-2 md:items-center md:gap-16"
    >
      <div>
        <div class="mb-6 flex flex-wrap gap-2">
          {
            project.onProgressTag && (
              <span class="tag tag--progress">
                <span class="tag-dot" />
                In progress
              </span>
            )
          }

          {
            project.workProjectTag && (
              <span class="tag tag--work">Work project</span>
            )
          }

          <span class="tag tag--type">{project.projectType}</span>
        </div>

        <h1
          transition:name={`project-title-${project.slug}`}
          class="detail-title gradient-text mb-4 text-2xl font-extrabold leading-[1.1]"
        >
          {project.name}
        </h1>

        <p class="text-sm font-normal text-text-secondary">
          {project.fullDescription}
        </p>

        <div class="mt-6 flex items-stretch gap-4">
          <div
            class="w-0.75 rounded-full bg-primary-2 shadow-[0_0_12px_rgba(83,235,243,0.35)]"
          >
          </div>

          <div>
            <span
              class="text-xs font-semibold uppercase tracking-wider text-secondary-5"
            >
              Categories
            </span>

            <p class="mt-1 text-sm text-white/70">
              {project.category.join(" | ")}
            </p>
          </div>
        </div>

        <div class="flex flex-wrap gap-4 pt-9">
          {
            project.liveUrl && (
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary-detail"
              >
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M6 4H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2M10 2h4m0 0v4m0-4L7 9"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                Live demo
              </a>
            )
          }

          {
            project.codeUrl && (
              <a
                href={project.codeUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-secondary-detail"
              >
                <Code />
                Source code
              </a>
            )
          }
        </div>
      </div>

      <div class="relative flex items-end justify-center py-4">
        {
          project.previewImages && (
            <div class="flex w-full max-w-125 items-end justify-center gap-4">
              <img
                src={project.previewImages[0].src}
                alt={`${project.name} screen 1`}
                loading="lazy"
                class="w-[35%] max-w-40 object-contain shadow-[0_20px_40px_rgba(0,0,0,0.5)]"
              />

              <img
                src={project.previewImages[1].src}
                alt={`${project.name} screen 2`}
                transition:name={`project-image-${project.slug}`}
                loading="eager"
                class="w-[45%] max-w-50 object-contain shadow-[0_24px_50px_rgba(0,0,0,0.65)]"
              />
            </div>
          )
        }
      </div>
    </section>

    <!-- TECH STACK -->
    <section class="container-main pb-18">
      <h2 class="section-heading">Tech Stack</h2>

      <div class="flex flex-wrap gap-2 md:gap-4">
        {
          project.technologiesIcons.map((tech) => {
            const Icon = tech.icon;

            return (
              <div class="tech-chip flex items-center gap-2 rounded-full bg-bg-surface px-4 py-2 text-sm font-semibold text-text-secondary outline-1 outline-secondary-1 transition-all duration-200 ease-in-out hover:outline-2 hover:outline-primary/70">
                <Icon class="h-5 w-5" />
                <span>{tech.label}</span>
              </div>
            );
          })
        }
      </div>
    </section>

    <!-- CHALLENGE & SOLUTION -->
    <section class="container-main">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
        <div class="cs-card">
          <div class="cs-icon cs-icon--challenge">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path
                d="M10 2L2 7v6l8 5 8-5V7L10 2z"
                stroke="#53EBF3"
                stroke-width="1.5"
                stroke-linejoin="round"
              ></path>
              <path
                d="M10 10v4M10 7v.5"
                stroke="#53EBF3"
                stroke-width="1.5"
                stroke-linecap="round"
              ></path>
            </svg>
          </div>

          <h3 class="cs-title">The Challenge</h3>
          <p class="cs-text">{project.challenge}</p>
        </div>

        <div class="cs-card">
          <div class="cs-icon cs-icon--solution">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="8" stroke="#3090E9" stroke-width="1.5"
              ></circle>
              <path
                d="M7 10l2 2 4-4"
                stroke="#3090E9"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              ></path>
            </svg>
          </div>

          <h3 class="cs-title">The Solution</h3>
          <p class="cs-text">{project.solution}</p>
        </div>
      </div>
    </section>

    <!-- FEATURES -->
    <section class="container-main pb-32 pt-18">
      <h2 class="section-heading">Key Features</h2>

      <div class="features-grid">
        {
          project.features.map((feature, i) => (
            <div class="feature-card" style={`--delay: ${i * 80}ms`}>
              <div class="feature-number">{String(i + 1).padStart(2, "0")}</div>
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-desc">{feature.description}</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</Layout>

<style is:global>
  .project-detail {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    color: white;
  }

  .project-detail > * {
    position: relative;
    z-index: 1;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 500;
    border: 1px solid;
  }

  .tag--progress {
    border-color: rgba(83, 235, 243, 0.3);
    color: var(--primary);
    background: rgba(83, 235, 243, 0.07);
  }

  .tag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--primary);
    box-shadow: 0 0 6px var(--primary);
    animation: pulse 1.6s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }

    50% {
      transform: scale(1.6);
      opacity: 0.6;
    }
  }

  .tag--work {
    border-color: rgba(48, 144, 233, 0.3);
    color: var(--primary-2);
    background: rgba(48, 144, 233, 0.07);
  }

  .tag--type {
    border-color: var(--secondary-1);
    color: var(--secondary-5);
    background: transparent;
  }

  .btn-primary-detail,
  .btn-secondary-detail {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.6rem 1.25rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary-detail {
    background: var(--primary-2);
    color: var(--dark);
    box-shadow: 0 0 20px rgba(48, 144, 233, 0.3);
  }

  .btn-primary-detail:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 28px rgba(48, 144, 233, 0.45);
  }

  .btn-secondary-detail {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
  }

  .btn-secondary-detail:hover {
    border-color: var(--primary);
    box-shadow: 0 0 16px rgba(83, 235, 243, 0.15);
  }

  .section-heading {
    font-size: 1.4rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 1.75rem;
    position: relative;
    padding-left: 1rem;
  }

  .section-heading::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 3px;
    height: 100%;
    background: var(--color-primary-2);
    border-radius: 999px;
  }

  .cs-card {
    padding: 1.75rem;
    border-radius: 24px;
    border: 1px solid var(--secondary-1);
    background: var(--bg-surface);
    position: relative;
    overflow: hidden;
  }

  .cs-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .cs-icon--challenge {
    background: rgba(83, 235, 243, 0.08);
    border: 1px solid rgba(83, 235, 243, 0.15);
  }

  .cs-icon--solution {
    background: rgba(48, 144, 233, 0.08);
    border: 1px solid rgba(48, 144, 233, 0.15);
  }

  .cs-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .cs-text {
    font-size: 0.9rem;
    color: var(--secondary-5);
    line-height: 1.7;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .feature-card {
    position: relative;
    padding: 1.75rem;
    border-radius: 24px;
    border: 1px solid var(--secondary-1);
    background: var(--bg-surface);
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0ms)
      forwards;
  }

  .feature-card:hover {
    border-color: rgba(83, 235, 243, 0.693);
    box-shadow: 0 0 24px rgba(83, 235, 243, 0.08);
    transform: translateY(-4px);
  }

  .feature-number {
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }

  .feature-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.6rem;
  }

  .feature-desc {
    font-size: 0.875rem;
    color: var(--secondary-5);
    line-height: 1.65;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>