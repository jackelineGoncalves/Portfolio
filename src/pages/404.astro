---
import Chevron from "../assets/svg/Chevron.astro";
import Button from "../components/ui/Button.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>404</title>
  </head>

  <body class="flex items-center justify-center">
    <canvas id="stars-canvas" class="stars"></canvas>

    <div class="top-glow"></div>

    <main
      class="container-main relative z-10 flex flex-col items-center text-center gap-10"
    >
      <div>
        <p class="code-line flex justify-center">
          <span class="kw">throw</span>
          <span class="kw">new</span>
          <span class="fn">Error</span>
          <span class="p">(</span>
          <span class="str">"404"</span>
          <span class="p">)</span>
        </p>

        <h1 class="error gradient-text text-center">404</h1>
        
        <div class="text-wrap text-center flex flex-col gap-4">
          <h3 class="text-xl font-semibold">Lost in the void</h3>
          <p class="text-white/50 mx-6">
            The page you're looking for is out of orbit. It may have been moved,
            removed, or never existed in this universe.
          </p>
        </div>
      </div>
        
      <Button label="Go back to home"  href="/"/>
    </main>

    <style>
     

      body {
        min-height: 100vh;
        overflow: hidden;
        font-family: Inter, system-ui, sans-serif;
        position: relative;

        background:
          radial-gradient(
            circle at top,
            rgba(28, 75, 110, 0.15),
            transparent 30%
          ),
          radial-gradient(
            circle at 80% 50%,
            rgba(63, 110, 180, 0.12),
            transparent 25%
          ),
          linear-gradient(180deg, #02060c 0%, #02080f 50%, #01040a 100%);

        color: white;
      }

      .stars {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }

      .top-glow {
        position: fixed;
        top: -10rem;
        left: 50%;
        transform: translateX(-50%);
        width: min(70rem, 90vw);
        height: 26rem;
        background: radial-gradient(
          ellipse,
          rgba(83, 235, 243, 0.12) 0%,
          transparent 70%
        );
        filter: blur(40px);
        pointer-events: none;
        z-index: 1;
      }

      .code-line {
        display: flex;
        gap: 0.3rem;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.85rem;
        opacity: 0.8;
      }

      .code-line::after {
        content: ";";
        color: rgba(255, 255, 255, 0.4);
      }

      .kw {
        color: #53ebf3;
      }

      .fn {
        color: #7dd3fc;
      }

      .str {
        color: #86efac;
      }

      .p {
        color: rgba(255, 255, 255, 0.6);
      }

      .error {
        font-size: clamp(6rem, 18vw, 12rem);
        font-weight: 900;
        letter-spacing: -0.05em;
        line-height: 1;
        margin: 0;
      }

      .text-wrap {
        max-width: 420px;
      }
    </style>

    <script is:inline>
      window.addEventListener("DOMContentLoaded", function () {
        const canvas = document.getElementById("stars-canvas");
        if (!(canvas instanceof HTMLCanvasElement)) return;

        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        function resize() {
          canvas.width = window.innerWidth;
          canvas.height = window.innerHeight;
        }

        resize();
        window.addEventListener("resize", resize);

        const stars = Array.from({ length: 160 }, function () {
          return {
            x: Math.random(),
            y: Math.random(),
            radius: Math.random() * 1.3 + 0.2,
            opacity: Math.random() * 0.5 + 0.15,
            speed: Math.random() * 0.008 + 0.002,
            offset: Math.random() * Math.PI * 2,
          };
        });

        let frame = 0;

        function draw() {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          frame++;

          for (const s of stars) {
            const alpha = Math.max(
              0.05,
              s.opacity + Math.sin(frame * s.speed + s.offset) * 0.25,
            );

            ctx.beginPath();
            ctx.arc(
              s.x * canvas.width,
              s.y * canvas.height,
              s.radius,
              0,
              Math.PI * 2,
            );
            ctx.fillStyle = `rgba(255,255,255,${alpha})`;
            ctx.fill();
          }

          requestAnimationFrame(draw);
        }

        draw();
      });
    </script>
  </body>
</html>
