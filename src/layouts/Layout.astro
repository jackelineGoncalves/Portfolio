---
import NavBar from "../components/ui/NavBar.astro";
import "../styles/global.css";

import type { Locale } from "../i18n/config";
import { ClientRouter } from "astro:transitions";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>
  </head>

  <body>
    <div id="intro-overlay">
      <div class="intro-code-window">
        <div class="intro-code-header">
          <span></span>
          <span></span>
          <span></span>
        </div>

        <div class="intro-code-body">
          <div class="intro-line line-1">
            <span class="code-keyword">const</span>
            <span class="code-variable"> developer</span>
            <span class="code-plain"> = </span>
            <span class="code-string">"Jackeline"</span>
            <span class="code-plain">;</span>
          </div>

          <div class="intro-line line-2">
            <span class="code-function">build</span>
            <span class="code-plain">(</span>
            <span class="code-string">"Digital experiences"</span>
            <span class="code-plain">);</span>
          </div>
        </div>
      </div>
    </div>

    <canvas
      id="stars-canvas"
      style="position:fixed; inset:0; width:100%; height:100%; pointer-events:none; z-index:0;"
    ></canvas>

    <main id="page-main" class="relative z-10">
       <NavBar lang={lang} />
      <slot />
    </main>

    <style>
      #intro-overlay {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background:
          radial-gradient(
            circle at top,
            rgba(83, 235, 243, 0.08),
            transparent 35%
          ),
          #02080f;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        transition:
          opacity 0.6s ease,
          visibility 0.6s ease;
      }

      #intro-overlay.hidden {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .intro-code-window {
        width: min(760px, 92vw);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        background: rgba(10, 16, 24, 0.82);
        backdrop-filter: blur(18px);
        box-shadow:
          0 25px 80px rgba(0, 0, 0, 0.45),
          inset 0 1px 0 rgba(255, 255, 255, 0.04);
        overflow: hidden;
        transform: translateY(20px) scale(0.98);
        opacity: 0;
        transition:
          opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .intro-code-window.show {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      .intro-code-header {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.95rem 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        background: rgba(255, 255, 255, 0.02);
      }

      .intro-code-header span {
        width: 0.7rem;
        height: 0.7rem;
        border-radius: 999px;
        display: block;
      }

      .intro-code-header span:nth-child(1) {
        background: rgba(255, 95, 86, 0.9);
      }

      .intro-code-header span:nth-child(2) {
        background: rgba(255, 189, 46, 0.9);
      }

      .intro-code-header span:nth-child(3) {
        background: rgba(39, 201, 63, 0.9);
      }

      .intro-code-body {
        padding: 1.5rem 1.25rem;
        display: grid;
        gap: 1rem;
      }

      .intro-line {
        position: relative;
        display: inline-block;
        width: 0;
        max-width: 100%;
        overflow: hidden;
        white-space: nowrap;
        font-family:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", "Courier New", monospace;
        font-size: clamp(0.95rem, 2.1vw, 1.45rem);
        line-height: 1.65;
        opacity: 1;
        border-right: 2px solid rgba(255, 255, 255, 0.95);
        vertical-align: top;
      }

      .line-1.typing,
      .line-2.typing {
        width: var(--target-width);
      }

      .line-1.typing {
        transition: width 1s steps(var(--steps, 30));
      }

      .line-2.typing {
        transition: width 1s steps(var(--steps, 30));
      }

      .intro-line.done {
        border-right-color: transparent;
      }

      .code-keyword {
        color: #53ebf3;
      }

      .code-variable {
        color: #ffffff;
      }

      .code-function {
        color: #7dd3fc;
      }

      .code-string {
        color: #a7f3d0;
      }

      .code-plain {
        color: rgba(255, 255, 255, 0.92);
      }

      #page-main {
        opacity: 0;
        transition: opacity 0.6s ease;
      }

      #page-main.revealed {
        opacity: 1;
      }

      @media (max-width: 640px) {
        .intro-code-window {
          border-radius: 20px;
        }

        .intro-code-body {
          padding: 1.15rem 1rem;
          gap: 0.8rem;
        }

        .intro-line {
          font-size: 0.9rem;
        }
      }
    </style>

    <script>
      (() => {
        const overlay = document.getElementById("intro-overlay");
        const windowEl = document.querySelector(".intro-code-window");
        const pageMain = document.getElementById("page-main");
        const line1 = document.querySelector<HTMLElement>(".line-1");
        const line2 = document.querySelector<HTMLElement>(".line-2");

        const prepareLine = (line: HTMLElement | null) => {
          if (!line) return;
          const text = (line.textContent || "").trim();
          const width = line.scrollWidth;
          line.style.setProperty("--target-width", `${width}px`);
          line.style.setProperty("--steps", `${text.length}`);
        };

        const prepareLines = () => {
          prepareLine(line1);
          prepareLine(line2);
        };

        requestAnimationFrame(() => {
          prepareLines();
        });

        window.addEventListener("resize", prepareLines);

        setTimeout(() => {
          windowEl?.classList.add("show");
        }, 100);

        setTimeout(() => {
          prepareLines();
          line1?.classList.add("typing");
        }, 500);

        setTimeout(() => {
          line1?.classList.add("done");
          prepareLines();
          line2?.classList.add("typing");
        }, 1800);

        setTimeout(() => {
          line2?.classList.add("done");
        }, 3200);

        setTimeout(() => {
          overlay?.classList.add("hidden");
          pageMain?.classList.add("revealed");
        }, 3600);

        setTimeout(() => {
          overlay?.remove();
        }, 4300);
      })();
    </script>

    <script>
      const canvas = document.getElementById(
        "stars-canvas",
      ) as HTMLCanvasElement;
      const ctx = canvas.getContext("2d")!;

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      resize();
      window.addEventListener("resize", resize);

      const NUM_STARS = 220;
      const stars = Array.from({ length: NUM_STARS }, () => ({
        x: Math.random(),
        y: Math.random(),
        radius: Math.random() * 1.4 + 0.2,
        opacity: Math.random() * 0.6 + 0.2,
        twinkleSpeed: Math.random() * 0.008 + 0.002,
        twinkleOffset: Math.random() * Math.PI * 2,
      }));

      interface ShootingStar {
        x: number;
        y: number;
        vx: number;
        vy: number;
        tailLength: number;
        life: number;
        maxLife: number;
      }

      const shootingStars: ShootingStar[] = [];

      function spawnShootingStar() {
        const speed = Math.random() * 5 + 4;
        const minDeg = 30;
        const maxDeg = 60;
        const baseDeg = minDeg + Math.random() * (maxDeg - minDeg);
        const quadrant = Math.floor(Math.random() * 4);

        let angleDeg: number;
        if (quadrant === 0) angleDeg = baseDeg;
        else if (quadrant === 1) angleDeg = 180 - baseDeg;
        else if (quadrant === 2) angleDeg = 180 + baseDeg;
        else angleDeg = 360 - baseDeg;

        const angle = angleDeg * (Math.PI / 180);
        const vx = Math.cos(angle) * speed;
        const vy = Math.sin(angle) * speed;

        let x: number, y: number;

        if (vx > 0 && vy > 0) {
          if (Math.random() < 0.5) {
            x = Math.random() * canvas.width;
            y = 0;
          } else {
            x = 0;
            y = Math.random() * canvas.height;
          }
        } else if (vx < 0 && vy > 0) {
          if (Math.random() < 0.5) {
            x = Math.random() * canvas.width;
            y = 0;
          } else {
            x = canvas.width;
            y = Math.random() * canvas.height;
          }
        } else if (vx < 0 && vy < 0) {
          if (Math.random() < 0.5) {
            x = Math.random() * canvas.width;
            y = canvas.height;
          } else {
            x = canvas.width;
            y = Math.random() * canvas.height;
          }
        } else {
          if (Math.random() < 0.5) {
            x = Math.random() * canvas.width;
            y = canvas.height;
          } else {
            x = 0;
            y = Math.random() * canvas.height;
          }
        }

        const stepsToExitX =
          vx > 0 ? (canvas.width - x) / vx : vx < 0 ? -x / vx : Infinity;
        const stepsToExitY =
          vy > 0 ? (canvas.height - y) / vy : vy < 0 ? -y / vy : Infinity;
        const maxLife = Math.min(stepsToExitX, stepsToExitY);

        shootingStars.push({
          x,
          y,
          vx,
          vy,
          tailLength: Math.random() * 80 + 80,
          life: 0,
          maxLife,
        });
      }

      function scheduleShootingStar() {
        const delay = Math.random() * 2500 + 2500;
        setTimeout(() => {
          spawnShootingStar();
          scheduleShootingStar();
        }, delay);
      }

      scheduleShootingStar();

      let frame = 0;

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        frame++;

        for (const s of stars) {
          const twinkle =
            Math.sin(frame * s.twinkleSpeed + s.twinkleOffset) * 0.3;
          const alpha = Math.max(0.05, s.opacity + twinkle);

          ctx.beginPath();
          ctx.arc(
            s.x * canvas.width,
            s.y * canvas.height,
            s.radius,
            0,
            Math.PI * 2,
          );
          ctx.fillStyle = `rgba(255, 255, 255, ${alpha})`;
          ctx.fill();
        }

        for (let i = shootingStars.length - 1; i >= 0; i--) {
          const s = shootingStars[i];
          s.life++;
          s.x += s.vx;
          s.y += s.vy;

          if (s.life >= s.maxLife) {
            shootingStars.splice(i, 1);
            continue;
          }

          const progress = s.life / s.maxLife;
          const fadeIn = Math.min(1, progress / 0.15);
          const fadeOut = Math.min(1, (1 - progress) / 0.15);
          const opacity = Math.min(fadeIn, fadeOut);

          const speed = Math.hypot(s.vx, s.vy);
          const tailX = s.x - s.vx * (s.tailLength / speed);
          const tailY = s.y - s.vy * (s.tailLength / speed);

          const grad = ctx.createLinearGradient(tailX, tailY, s.x, s.y);
          grad.addColorStop(0, `rgba(255, 255, 255, 0)`);
          grad.addColorStop(0.6, `rgba(255, 255, 255, ${opacity * 0.4})`);
          grad.addColorStop(1, `rgba(255, 255, 255, ${opacity})`);

          ctx.beginPath();
          ctx.moveTo(tailX, tailY);
          ctx.lineTo(s.x, s.y);
          ctx.strokeStyle = grad;
          ctx.lineWidth = 1.5;
          ctx.stroke();

          ctx.beginPath();
          ctx.arc(s.x, s.y, 1.8, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 255, 255, ${opacity})`;
          ctx.fill();
        }

        requestAnimationFrame(draw);
      }

      draw();
    </script>
  </body>
</html>







